# Copy this file to .env.deploy.local and fill in your values.

DEPLOY_HOST=your_server_ip_here
DEPLOY_PORT=22
DEPLOY_USERNAME=your_username_here
DEPLOY_PASSWORD=your_password_here
# DEPLOY_PRIVATE_KEY_PATH=C:/Users/admin/.ssh/id_rsa
# DEPLOY_PASSPHRASE=

DEPLOY_TARGETS=client,server

DEPLOY_CLIENT_BUILD_COMMAND=pnpm -F @cloud-gallery/web build
DEPLOY_CLIENT_LOCAL_DIR=apps/web/dist
DEPLOY_CLIENT_REMOTE_DIR=your_remote_path_here/client
DEPLOY_CLIENT_CLEAN_REMOTE=false

DEPLOY_SERVER_BUILD_COMMAND=pnpm -C server build
DEPLOY_SERVER_LOCAL_DIR=server/dist
DEPLOY_SERVER_REMOTE_DIR=your_remote_path_here/server/dist
DEPLOY_SERVER_CLEAN_REMOTE=false