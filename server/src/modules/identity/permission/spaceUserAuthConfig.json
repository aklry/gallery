{
    "permissions": [
        {
            "key": "space:view",
            "name": "查看空间",
            "description": "查看空间详情和空间内资源"
        },
        {
            "key": "space:analyze",
            "name": "空间分析",
            "description": "查看空间分析数据"
        },
        {
            "key": "spaceUser:manage",
            "name": "成员管理",
            "description": "管理空间成员，添加、移除或调整角色"
        },
        {
            "key": "space:invite",
            "name": "邀请码管理",
            "description": "生成、查看和失效空间邀请码"
        },
        {
            "key": "picture:view",
            "name": "查看图片",
            "description": "查看空间中的图片内容"
        },
        {
            "key": "picture:upload",
            "name": "上传图片",
            "description": "上传图片到空间中"
        },
        {
            "key": "picture:edit",
            "name": "编辑图片",
            "description": "修改已上传图片的信息"
        },
        {
            "key": "picture:delete",
            "name": "删除图片",
            "description": "删除空间中的图片"
        }
    ],
    "roles": [
        {
            "key": "viewer",
            "name": "浏览者",
            "permissions": ["space:view", "space:invite", "picture:view"],
            "description": "查看空间、查看图片并生成邀请码"
        },
        {
            "key": "editor",
            "name": "编辑者",
            "permissions": [
                "space:view",
                "space:invite",
                "picture:view",
                "picture:upload",
                "picture:edit",
                "picture:delete"
            ],
            "description": "查看空间、管理图片并生成邀请码"
        },
        {
            "key": "admin",
            "name": "管理员",
            "permissions": [
                "space:view",
                "space:analyze",
                "spaceUser:manage",
                "space:invite",
                "picture:view",
                "picture:upload",
                "picture:edit",
                "picture:delete"
            ],
            "description": "查看空间、分析数据、管理成员、管理邀请码并管理图片"
        }
    ]
}
