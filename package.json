{
    "name": "cloud-gallery",
    "version": "1.0.0",
    "description": "画云间",
    "main": "index.js",
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=9.12.1 < 10.0.0"
    },
    "packageManager": "pnpm@9.12.1",
    "scripts": {
        "dev:client": "pnpm -F @cloud-gallery/web dev",
        "dev:server": "pnpm -C server start:dev",
        "dev": "concurrently \"pnpm -F @cloud-gallery/web dev\" \"pnpm -C server start:dev\"",
        "prepare": "husky",
        "in": "pnpm i -r",
        "format": "pnpm -F @cloud-gallery/web format&&pnpm -C server format",
        "lint": "pnpm -F @cloud-gallery/web lint&&pnpm -C server lint",
        "lint:lint-staged": "lint-staged",
        "lint:style": "pnpm -F @cloud-gallery/web lint:style",
        "commit": "cz",
        "generate:api": "pnpm -F @cloud-gallery/web generate:api",
        "generate:db": "pnpm -C server generate:db",
        "pull:db": "pnpm -C server pull:db",
        "clear": "rimraf --glob node_modules apps/*/node_modules server/node_modules",
        "build": "concurrently --kill-others-on-fail --success all \"pnpm -F @cloud-gallery/web build\" \"pnpm -C server build\"",
        "push:deploy": "node ./scripts/push-deploy.mjs",
        "deploy:upload": "node ./scripts/push-deploy.mjs --skip-push"
    },
    "keywords": [
        "云图库",
        "自定义图库",
        "个人空间"
    ],
    "author": "aklry",
    "config": {
        "commitizen": {
            "path": "cz-vinyl"
        }
    },
    "lint-staged": {
        "*.{ts,vue,js}": [
            "pnpm lint",
            "pnpm format"
        ],
        "*.{css,scss,vue}": [
            "pnpm lint:style"
        ]
    },
    "license": "ISC",
    "devDependencies": {
        "@commitlint/cli": "^19.6.0",
        "@commitlint/config-conventional": "^19.6.0",
        "@types/crypto-js": "^4.2.2",
        "@types/md5": "^2.3.6",
        "@types/node": "^20.3.1",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "commitizen": "^4.3.1",
        "concurrently": "^9.1.0",
        "cz-vinyl": "^2.5.4",
        "eslint": "^8.0.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "eslint-plugin-vue": "^9.32.0",
        "husky": "^9.1.7",
        "inquirer": "^8.0.0",
        "lint-staged": "^15.2.10",
        "prettier": "^3.0.0",
        "ssh2-sftp-client": "^12.1.1"
    },
    "dependencies": {
        "axios": "^1.7.9",
        "crypto-js": "^4.2.0",
        "md5": "^2.3.0"
    }
}
